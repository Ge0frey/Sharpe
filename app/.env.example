# Copy to .env.local for local dev; set the same keys in the Vercel dashboard
# (Production + Preview) before the first build. Vite inlines VITE_* at BUILD
# time, so a variable added after a deploy does nothing until you rebuild.
#
# config.ts falls back to these exact defaults with `??`. An empty string is not
# nullish — setting a key to "" yields e.g. CFG.rpc === "" and every call fails.
# Set a real value or leave the variable out entirely.

# Leave as /txapi. TxOdds sends no CORS headers, so the browser cannot call it
# directly — /txapi is proxied server-side (vite.config.ts in dev, vercel.json in
# prod) to https://txline-dev.txodds.com. Only override to hit the API directly
# from a non-browser context.
VITE_TXLINE_API=/txapi

# api.devnet.solana.com works but throttles getProgramAccounts hard, which
# Portfolio, Duels and Leaderboard hit on every render. Use a dedicated RPC.
VITE_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# Display-only: rendered in Footer.tsx and Landing.tsx. The program the app
# actually talks to comes from the "address" field of src/chain/idl/clv.json.
VITE_CLV_PROGRAM=734ZWmPmAMGSjCshLCJQRpPNiaWBQsdaZDkvP3MAGmLz

VITE_TXORACLE_PROGRAM=6pW64gN1s2uqjHkn1unFeEjAwJkPGHoppGvS715wyP2J
